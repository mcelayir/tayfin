# === Database (shared by all DB-connected services) ===
# Ref: ADR-05 § Database Variables, ADR-06 § Default Credential Policy
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tayfin
POSTGRES_USER=tayfin_user
POSTGRES_PASSWORD=tayfin_password

# === Inter-Service URLs (override for Docker Compose) ===
# Ref: ADR-05 §4 — Docker Compose sets these automatically via
# environment blocks in docker-compose.yml.  The values below are
# localhost defaults for running services outside Docker.
TAYFIN_INGESTOR_API_BASE_URL=http://localhost:8000
TAYFIN_INDICATOR_API_BASE_URL=http://localhost:8010
TAYFIN_SCREENER_API_BASE_URL=http://localhost:8020

OHLCV_PROVIDER_MAX_RETRIES=1
OHLCV_PROVIDER_BACKOFF_SECONDS=2.0
OHLCV_TV_MIN_DELAY_SECONDS=2.0