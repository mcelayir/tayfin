{
  "$id": "https://tayfin.local/schemas/indicator_range.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Indicator Range Response",
  "type": "object",
  "properties": {
    "ticker": {"type": "string"},
    "indicator": {"type": "string"},
    "params": {"type": "object", "properties": {"window": {"type": "integer"}}},
    "from": {"type": "string", "format": "date"},
    "to": {"type": "string", "format": "date"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": {"type": "string", "format": "date"},
          "value": {"type": "number"}
        },
        "required": ["date","value"]
      }
    }
  },
  "required": ["ticker","indicator","from","to","items"]
}
