{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FundamentalsList",
  "type": "object",
  "required": ["symbol","count","items"],
  "properties": {
    "symbol": {"type": "string"},
    "country": {"type": "string"},
    "from": {"type": "string","format":"date"},
    "to": {"type": "string","format":"date"},
    "count": {"type":"integer"},
    "items": {
      "type": "array",
      "items": {"$ref":"./fundamentals_latest.json"}
    }
  },
  "additionalProperties": false
}
